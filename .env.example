# Telegram Bot API token (@BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Cookie sessionid из авторизованной сессии браузера
SESSION_TOKEN=your_session_id_here

# Опционально: csrftoken из cookies (улучшает стабильность)
CSRF_TOKEN=

# Опциональные настройки «тихого» режима
REQUEST_DELAY_SEC=1.5
MAX_RETRIES=3
RETRY_BACKOFF_SEC=2.0
PAGINATION_PAGE_SIZE=12
MAX_PAGINATION_PAGES=50