# Telegram Bot API token (@BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Cookie sessionid из браузера (F12 → Application → Cookies → instagram.com)
# Можно вставить целиком: sessionid=7534...%3Axxx%3A24%3A...
SESSION_TOKEN=your_session_id_here

# csrftoken из тех же cookies — ОБЯЗАТЕЛЕН для стабильной работы
CSRF_TOKEN=your_csrf_token_here

# Опциональные настройки сбора
REQUEST_DELAY_SEC=0.4
MAX_CONCURRENT_REQUESTS=8
MAX_RETRIES=2
RETRY_BACKOFF_SEC=1.5
PAGINATION_PAGE_SIZE=24
MAX_PAGINATION_PAGES=100
COMMENTS_PAGE_SIZE=50
MAX_COMMENT_PAGES=20

# Профиль — быстрый режим (2 страницы ≈ 48 постов/reels)
PROFILE_MAX_PAGES=2
PROFILE_MAX_TAGGED_PAGES=1
PROFILE_ENRICH_TOP_POSTS=2
PROFILE_MAX_HIGHLIGHTS_FETCH=0