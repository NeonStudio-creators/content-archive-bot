# === Локальный запуск (рекомендуется для YouTube) ===
# Windows:  .\scripts\local\install.ps1  →  заполните .env  →  .\scripts\local\run.ps1
# Linux VPS: ./scripts/local/install.sh  →  nano .env  →  ./scripts/local/run.sh
# Важно: остановите Railway Worker с тем же TELEGRAM_BOT_TOKEN (иначе конфликт polling).
# Node.js 20+ желателен — yt-dlp использует его для YouTube.

# Telegram Bot API token (@BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Cookie sessionid из браузера (F12 → Application → Cookies → instagram.com)
# Можно вставить целиком: sessionid=7534...%3Axxx%3A24%3A...
SESSION_TOKEN=your_session_id_here

# csrftoken из тех же cookies — опционально (бот обновляет сам при старте)
# CSRF_TOKEN=your_csrf_token_here

# Кэш обновлённых cookies между перезапусками (по умолчанию .token_cache.json)
# TOKEN_CACHE_PATH=.token_cache.json

# Интервал фонового обновления cookies в секундах (0 = только при старте и ошибках)
TOKEN_REFRESH_INTERVAL_SEC=1800

# Опциональные настройки сбора
REQUEST_DELAY_SEC=0.4
MAX_CONCURRENT_REQUESTS=8
MAX_RETRIES=2
RETRY_BACKOFF_SEC=1.5
PAGINATION_PAGE_SIZE=24
MAX_PAGINATION_PAGES=100
COMMENTS_PAGE_SIZE=50
MAX_COMMENT_PAGES=20

# Профиль — быстрый режим (2 страницы ≈ 48 постов/reels)
PROFILE_MAX_PAGES=2
PROFILE_MAX_TAGGED_PAGES=1
PROFILE_ENRICH_TOP_POSTS=2
PROFILE_MAX_HIGHLIGHTS_FETCH=0

# TikTok — cookie sessionid (F12 → Cookies → tiktok.com → sessionid)
# Можно целиком: sessionid=abc123%7C...
TIKTOK_SESSION_TOKEN=your_tiktok_sessionid_here

# Опционально: tt_csrf_token с той же страницы cookies
# TIKTOK_CSRF_TOKEN=your_tt_csrf_token_here

# YouTube — cookies из браузера (F12 → Application → Cookies → youtube.com)
# Вариант 1 — одна строка через «;»:
# YOUTUBE_SESSION_TOKEN=SID=...; SAPISID=...; __Secure-1PSID=...; __Secure-1PAPISID=...
# Вариант 2 — каждый cookie с новой строки (RAW в Railway):
# YOUTUBE_SESSION_TOKEN=SID=...
# SAPISID=...
# __Secure-1PSID=...
# __Secure-1PAPISID=...
# Вариант 3 — отдельные переменные:
# YOUTUBE_SID=...
# YOUTUBE_SAPISID=...
# YOUTUBE_SECURE_1PSID=...
# YOUTUBE_SECURE_1PAPISID=...